{
  "umbrella_project": "ai",
  "umbrella_chroot_arches": ["aarch64", "x86_64"],
  "chroot_exclude_distros": [
    "epel-7",
    "epel-8",
    "mageia",
    "rhel-7",
    "rhel-8",
    "centos-stream-8",
    "centos-stream+epel-next-8",
    "custom",
    "fedora-eln",
    "almalinux-kitten-10",
    "alma-kitten+epel-10",
    "openeuler"
  ],
  "packages": [
    {
      "chroot_arches": ["aarch64", "x86_64"],
      "name": "gogcli",
      "project": "gogcli",
      "subdir": "packages/gogcli",
      "spec": "gogcli.spec",
      "upstream_url": "https://github.com/steipete/gogcli.git",
      "tag_prefix": "v"
    },
    {
      "chroot_arches": ["aarch64", "x86_64"],
      "name": "wacli",
      "project": "wacli",
      "subdir": "packages/wacli",
      "spec": "wacli.spec",
      "upstream_url": "https://github.com/steipete/wacli.git",
      "tag_prefix": "v"
    },
    {
      "chroot_arches": ["aarch64", "x86_64"],
      "name": "codex",
      "project": "codex",
      "subdir": "packages/codex",
      "spec": "codex.spec",
      "upstream_url": "https://github.com/openai/codex.git",
      "tag_prefix": "rust-v"
    },
    {
      "chroot_arches": ["aarch64", "x86_64"],
      "name": "opencode",
      "project": "opencode",
      "subdir": "packages/opencode",
      "spec": "opencode.spec",
      "upstream_url": "https://github.com/anomalyco/opencode.git",
      "tag_prefix": "v"
    },
    {
      "chroot_arches": ["aarch64", "x86_64"],
      "name": "ollama",
      "project": "ollama",
      "subdir": "packages/ollama",
      "spec": "ollama.spec",
      "upstream_url": "https://github.com/ollama/ollama.git",
      "tag_prefix": "v"
    },
    {
      "chroot_arches": ["aarch64", "x86_64"],
      "name": "claude-code",
      "project": "claude-code",
      "subdir": "packages/claude-code",
      "spec": "claude-code.spec",
      "npm_package": "@anthropic-ai/claude-code"
    },
    {
      "chroot_arches": ["aarch64", "x86_64"],
      "name": "hermes-agent",
      "project": "hermes-agent",
      "subdir": "packages/hermes-agent",
      "spec": "hermes-agent.spec",
      "upstream_url": "https://github.com/NousResearch/hermes-agent.git",
      "tag_prefix": "v",
      "tag_version_pattern": "(\\d{4}\\.\\d+\\.\\d+)",
      "version_source": "pyproject"
    }
  ]
}
