{
  "umbrella_project": "ai",
  "umbrella_chroot_arches": ["aarch64", "x86_64"],
  "chroot_exclude_distros": [
    "epel-7",
    "epel-8",
    "mageia",
    "rhel-7",
    "rhel-8",
    "centos-stream-8",
    "centos-stream+epel-next-8",
    "custom",
    "fedora-eln",
    "almalinux-kitten-10",
    "alma-kitten+epel-10",
    "openeuler"
  ],
  "packages": [
    {
      "chroot_arches": ["aarch64", "x86_64"],
      "name": "gogcli",
      "project": "gogcli",
      "subdir": "packages/gogcli",
      "spec": "gogcli.spec",
      "upstream_url": "https://github.com/openclaw/gogcli.git",
      "tag_prefix": "v"
    },
    {
      "chroot_arches": ["aarch64", "x86_64"],
      "name": "wacli",
      "project": "wacli",
      "subdir": "packages/wacli",
      "spec": "wacli.spec",
      "upstream_url": "https://github.com/openclaw/wacli.git",
      "tag_prefix": "v"
    },
    {
      "chroot_arches": ["aarch64", "x86_64"],
      "name": "codex",
      "project": "codex",
      "subdir": "packages/codex",
      "spec": "codex.spec",
      "upstream_url": "https://github.com/openai/codex.git",
      "tag_prefix": "rust-v"
    },
    {
      "chroot_arches": ["aarch64", "x86_64"],
      "name": "opencode",
      "project": "opencode",
      "subdir": "packages/opencode",
      "spec": "opencode.spec",
      "upstream_url": "https://github.com/anomalyco/opencode.git",
      "tag_prefix": "v"
    },
    {
      "chroot_arches": ["aarch64", "x86_64"],
      "name": "ollama",
      "project": "ollama",
      "subdir": "packages/ollama",
      "spec": "ollama.spec",
      "upstream_url": "https://github.com/ollama/ollama.git",
      "tag_prefix": "v"
    },
    {
      "chroot_arches": ["aarch64", "x86_64"],
      "name": "claude-code",
      "project": "claude-code",
      "subdir": "packages/claude-code",
      "spec": "claude-code.spec",
      "npm_package": "@anthropic-ai/claude-code"
    },
    {
      "chroot_arches": ["aarch64", "x86_64"],
      "name": "nodejs25-caged",
      "project": "nodejs25-caged",
      "subdir": "packages/nodejs25-caged",
      "spec": "nodejs25-caged.spec",
      "node_major": 25,
      "timeout": 43200,
      "max_builds": 5,
      "exclude_distros": ["opensuse-leap", "opensuse-tumbleweed"]
    }
  ]
}
